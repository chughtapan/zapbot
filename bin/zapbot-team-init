#!/usr/bin/env bash
set -euo pipefail

# zapbot-team-init — Configure a GitHub repo for the zapbot workflow.
# Creates required labels, initializes SQLite database, and generates
# agent-orchestrator config from templates.

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
GITHUB_USER=$(gh api user --jq '.login' 2>/dev/null || echo "")
ZAPBOT_REPO="${1:-}"

if [ -z "$ZAPBOT_REPO" ]; then
  echo "Usage: zapbot-team-init <owner/repo>"
  echo "  Example: zapbot-team-init chughtapan/my-project"
  exit 1
fi

if [ -z "$GITHUB_USER" ]; then
  echo "ERROR: Not authenticated with GitHub. Run: gh auth login"
  exit 1
fi

echo "=== Zapbot Team Init ==="
echo "Repo: $ZAPBOT_REPO"
echo ""

# ── 1. Create GitHub labels ─────────────────────────────────────────

echo "--- Creating labels ---"
LABELS=(
  "triage:D93F0B:Parent issue in triage"
  "triaged:FBCA04:Triage complete, sub-issues in progress"
  "planning:BFD4F2:Plan in progress"
  "review:0E8A16:Plan under review"
  "plan-approved:1D76DB:Plan approved for implementation"
  "implementing:5319E7:Agent implementing code"
  "draft-review:C2E0C6:Draft PR under human review"
  "verifying:006B75:QE agent verifying"
  "abandoned:E4E669:Workflow abandoned"
  "zapbot-plan:0E8A16:Plan published via zapbot"
)

for entry in "${LABELS[@]}"; do
  IFS=: read -r name color desc <<< "$entry"
  gh label create "$name" \
    --repo "$ZAPBOT_REPO" \
    --color "$color" \
    --description "$desc" \
    --force 2>/dev/null || true
  echo "  Label: $name"
done

# ── 2. Initialize SQLite database ───────────────────────────────────

echo ""
echo "--- Initializing database ---"
ZAPBOT_DIR="$HOME/.zapbot"
mkdir -p "$ZAPBOT_DIR/logs"

if [ -f "$ZAPBOT_DIR/state.db" ]; then
  echo "  Database already exists at $ZAPBOT_DIR/state.db"
else
  echo "  Database will be created on first bridge start at $ZAPBOT_DIR/state.db"
fi

# ── 3. Generate agent-orchestrator.yaml from template ────────────────

echo ""
echo "--- Generating agent-orchestrator.yaml ---"
TEMPLATE="$REPO_DIR/templates/agent-orchestrator.yaml.tmpl"
if [ -f "$TEMPLATE" ]; then
  REPO_PATH=$(pwd)
  REPO_NAME=$(basename "$ZAPBOT_REPO")
  sed \
    -e "s|{{REPO}}|$ZAPBOT_REPO|g" \
    -e "s|{{REPO_PATH}}|$REPO_PATH|g" \
    -e "s|{{REPO_NAME}}|$REPO_NAME|g" \
    "$TEMPLATE" > "$REPO_DIR/agent-orchestrator.yaml"
  echo "  Generated agent-orchestrator.yaml"
else
  echo "  Template not found at $TEMPLATE, skipping"
fi

# ── 4. Generate agent rules from template ────────────────────────────

echo ""
echo "--- Generating .agent-rules.md ---"
RULES_TEMPLATE="$REPO_DIR/templates/agent-rules.md.tmpl"
if [ -f "$RULES_TEMPLATE" ]; then
  cp "$RULES_TEMPLATE" "$REPO_DIR/.agent-rules.md"
  echo "  Generated .agent-rules.md"
else
  echo "  Template not found at $RULES_TEMPLATE, skipping"
fi

# ── 5. Configure webhook ────────────────────────────────────────────

echo ""
echo "--- Webhook setup ---"
echo "  To set up the webhook, run ./start.sh which handles ngrok + webhook automatically."
echo "  Or manually create a webhook at:"
echo "    https://github.com/$ZAPBOT_REPO/settings/hooks/new"
echo "  Payload URL: <your-ngrok-url>/api/webhooks/github"
echo "  Content type: application/json"
echo "  Events: Issues, Pull requests, Pull request reviews"

# ── Done ─────────────────────────────────────────────────────────────

echo ""
echo "================================================"
echo "  Team init complete for $ZAPBOT_REPO!"
echo "================================================"
echo ""
echo "Next steps:"
echo "  1. Run ./start.sh to start the bridge"
echo "  2. Create an issue with the 'triage' label to kick off a workflow"
echo ""
