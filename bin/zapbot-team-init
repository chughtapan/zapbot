#!/usr/bin/env bash
set -euo pipefail

# zapbot-team-init — Configure a GitHub repo for the zapbot workflow.
# Creates the plan label and generates agent-orchestrator config.
#
# Usage:
#   zapbot-team-init <owner/repo>              — full init (first repo)
#   zapbot-team-init --add-repo <owner/repo>   — add a repo to existing config

ZAPBOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
GITHUB_USER=$(gh api user --jq '.login' 2>/dev/null || echo "")

# ── Parse args ──────────────────────────────────────────────────────

ADD_REPO_MODE=false
ZAPBOT_REPO=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --add-repo)
      ADD_REPO_MODE=true
      shift
      ;;
    --help|-h)
      echo "Usage:"
      echo "  zapbot-team-init <owner/repo>               Full init (first repo)"
      echo "  zapbot-team-init --add-repo <owner/repo>    Add repo to existing config"
      exit 0
      ;;
    *)
      ZAPBOT_REPO="$1"
      shift
      ;;
  esac
done

if [ -z "$ZAPBOT_REPO" ]; then
  echo "Usage: zapbot-team-init <owner/repo>"
  echo "       zapbot-team-init --add-repo <owner/repo>"
  exit 1
fi

if [ -z "$GITHUB_USER" ]; then
  echo "ERROR: Not authenticated with GitHub. Run: gh auth login"
  exit 1
fi

REPO_NAME=$(basename "$ZAPBOT_REPO")
PROJECT_DIR=$(pwd)

LABELS=(
  "zapbot-plan:0E8A16:Plan published via zapbot"
)

create_labels() {
  local repo="$1"
  for entry in "${LABELS[@]}"; do
    IFS=: read -r name color desc <<< "$entry"
    gh label create "$name" \
      --repo "$repo" \
      --color "$color" \
      --description "$desc" \
      --force 2>/dev/null || true
    echo "  Label: $name"
  done
}

# ── Add-repo mode: append project to existing config ────────────────

if [ "$ADD_REPO_MODE" = true ]; then
  CONFIG_FILE="$PROJECT_DIR/agent-orchestrator.yaml"
  if [ ! -f "$CONFIG_FILE" ]; then
    echo "ERROR: No agent-orchestrator.yaml found in $PROJECT_DIR"
    echo "Run zapbot-team-init <owner/repo> in this project first."
    exit 1
  fi

  if grep -q "repo: ${ZAPBOT_REPO}" "$CONFIG_FILE" 2>/dev/null; then
    echo "ERROR: ${ZAPBOT_REPO} is already configured in agent-orchestrator.yaml"
    exit 1
  fi

  echo "=== Adding repo: $ZAPBOT_REPO ==="
  echo ""
  echo "--- Creating labels on $ZAPBOT_REPO ---"
  create_labels "$ZAPBOT_REPO"

  echo ""
  echo "--- Adding project to agent-orchestrator.yaml ---"

  PROJECT_BLOCK="
  ${REPO_NAME}:
    repo: ${ZAPBOT_REPO}
    path: ${PROJECT_DIR}
    defaultBranch: main
    scm:
      plugin: github
      webhook:
        path: /api/webhooks/github
        secretEnvVar: ZAPBOT_WEBHOOK_SECRET
        signatureHeader: x-hub-signature-256
        eventHeader: x-github-event"

  echo "$PROJECT_BLOCK" >> "$CONFIG_FILE"
  echo "  Added project: $REPO_NAME (${ZAPBOT_REPO})"

  echo ""
  echo "================================================"
  echo "  Added $ZAPBOT_REPO to zapbot!"
  echo "================================================"
  echo ""
  echo "Reload the bridge to pick up the new project:"
  if systemctl is-active zapbot-bridge >/dev/null 2>&1; then
    sudo systemctl reload zapbot-bridge 2>/dev/null && echo "  Bridge reloaded." || echo "  Run: sudo systemctl reload zapbot-bridge"
  else
    echo "  Restart ./start.sh"
  fi
  echo ""
  exit 0
fi

# ── Full init mode (first repo) ────────────────────────────────────

echo "=== Zapbot Team Init ==="
echo "Repo: $ZAPBOT_REPO"
echo ""

echo "--- Creating labels ---"
create_labels "$ZAPBOT_REPO"

echo ""
echo "--- Generating agent-orchestrator.yaml ---"
TEMPLATE="$ZAPBOT_DIR/templates/agent-orchestrator.yaml.tmpl"
if [ -f "$TEMPLATE" ]; then
  sed \
    -e "s|{{REPO}}|$ZAPBOT_REPO|g" \
    -e "s|{{REPO_PATH}}|$PROJECT_DIR|g" \
    -e "s|{{REPO_NAME}}|$REPO_NAME|g" \
    "$TEMPLATE" > "$PROJECT_DIR/agent-orchestrator.yaml"
  echo "  Generated $PROJECT_DIR/agent-orchestrator.yaml"
else
  echo "  Template not found at $TEMPLATE, skipping"
fi

echo ""
echo "--- Environment setup ---"
ENV_FILE="$PROJECT_DIR/.env"
if [ ! -f "$ENV_FILE" ]; then
  GENERATED_API_KEY=$(openssl rand -hex 32 2>/dev/null || head -c 64 /dev/urandom | xxd -p | tr -d '\n')
  GENERATED_WEBHOOK_SECRET=$(openssl rand -hex 32 2>/dev/null || head -c 64 /dev/urandom | xxd -p | tr -d '\n')
  cat > "$ENV_FILE" <<EOF
# Zapbot environment — generated by zapbot-team-init
#
# Two distinct secrets:
#   ZAPBOT_WEBHOOK_SECRET  — HMAC-SHA256 secret GitHub uses to sign webhooks.
#                            Also configured on the GitHub App "Webhook secret".
#   ZAPBOT_API_KEY         — Bearer for the local broker (GET /api/tokens/installation).
#                            Never hand this to GitHub.
ZAPBOT_WEBHOOK_SECRET=${GENERATED_WEBHOOK_SECRET}
ZAPBOT_API_KEY=${GENERATED_API_KEY}

# Bridge port (default: 3000)
# ZAPBOT_PORT=3000

# Per-repo webhook secrets (optional, overrides shared ZAPBOT_WEBHOOK_SECRET):
# ZAPBOT_WEBHOOK_SECRET_FRONTEND_APP=<secret>

# Gateway registration (if using the hosted gateway):
# ZAPBOT_GATEWAY_URL=https://zapbot-gateway.up.railway.app
# ZAPBOT_GATEWAY_SECRET=<must match GATEWAY_SECRET on the gateway>
# ZAPBOT_BRIDGE_URL=<public URL of this bridge>

# GitHub auth for state reads (pick one):
# ZAPBOT_GITHUB_TOKEN=<PAT>
# or GitHub App:
# GITHUB_APP_ID=<app id>
# GITHUB_APP_INSTALLATION_ID=<installation id>
# GITHUB_APP_PRIVATE_KEY=<pem contents or path to pem>
EOF
  echo "  Generated .env with webhook secret + broker API key"
else
  echo "  $ENV_FILE already exists, skipping"
fi

echo ""
echo "--- Webhook setup ---"
echo "  Configure a GitHub App or repo webhook to deliver to:"
echo "    <bridge or gateway URL>/api/webhooks/github"
echo "  Use ZAPBOT_WEBHOOK_SECRET as the webhook secret."
echo "  ZAPBOT_API_KEY is the broker bearer — it stays local."

echo ""
if systemctl is-active zapbot-bridge >/dev/null 2>&1; then
  echo "Reloading bridge config (systemd service detected)..."
  sudo systemctl reload zapbot-bridge 2>/dev/null && echo "  Bridge reloaded." || echo "  WARNING: Could not reload. Run: sudo systemctl reload zapbot-bridge"
fi

echo ""
echo "================================================"
echo "  Team init complete for $ZAPBOT_REPO!"
echo "================================================"
echo ""
echo "Next steps:"
if systemctl is-active zapbot-bridge >/dev/null 2>&1; then
  echo "  1. Bridge is running (systemd). Config was auto-reloaded."
else
  echo "  1. Run $ZAPBOT_DIR/start.sh . to start the bridge"
fi
echo "  2. Mention @zapbot on an issue to kick off a plan or investigation"
echo "     zapbot will dispatch a direct ao session; optional MoltZap env is forwarded if configured"
echo ""
echo "To add another repo later:"
echo "  cd ~/other-project"
echo "  $ZAPBOT_DIR/bin/zapbot-team-init --add-repo <owner/other-repo>"
echo ""
