#!/usr/bin/env bash
set -euo pipefail

# zapbot-team-init — Configure a GitHub repo for the zapbot workflow.
# Creates the plan label and registers the project in
# ~/.zapbot/projects.json (the orchestrator's project loader source).
#
# Usage:
#   zapbot-team-init <owner/repo>              — full init (first repo)
#   zapbot-team-init --add-repo <owner/repo>   — add a repo to existing config

ZAPBOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
GITHUB_USER=$(gh api user --jq '.login' 2>/dev/null || echo "")
PROJECTS_JSON="$HOME/.zapbot/projects.json"

# ── Parse args ──────────────────────────────────────────────────────

ADD_REPO_MODE=false
ZAPBOT_REPO=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --add-repo)
      ADD_REPO_MODE=true
      shift
      ;;
    --help|-h)
      echo "Usage:"
      echo "  zapbot-team-init <owner/repo>               Full init (first repo)"
      echo "  zapbot-team-init --add-repo <owner/repo>    Add repo to existing config"
      exit 0
      ;;
    *)
      ZAPBOT_REPO="$1"
      shift
      ;;
  esac
done

if [ -z "$ZAPBOT_REPO" ]; then
  echo "Usage: zapbot-team-init <owner/repo>"
  echo "       zapbot-team-init --add-repo <owner/repo>"
  exit 1
fi

if [ -z "$GITHUB_USER" ]; then
  echo "ERROR: Not authenticated with GitHub. Run: gh auth login"
  exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "ERROR: jq is required. Install jq (e.g. brew install jq or apt install jq)"
  exit 1
fi

REPO_NAME=$(basename "$ZAPBOT_REPO")

LABELS=(
  "zapbot-plan:0E8A16:Plan published via zapbot"
)

create_labels() {
  local repo="$1"
  for entry in "${LABELS[@]}"; do
    IFS=: read -r name color desc <<< "$entry"
    gh label create "$name" \
      --repo "$repo" \
      --color "$color" \
      --description "$desc" \
      --force 2>/dev/null || true
    echo "  Label: $name"
  done
}

# Atomically merge a project entry into ~/.zapbot/projects.json. Schema
# matches `bin/zapbot-orchestrator.ts`'s `ProjectsFileSchema`:
#   { "<slug>": { "repo": "owner/name", "defaultBranch": "main" } }
upsert_project_entry() {
  local slug="$1"
  local repo="$2"
  local default_branch="${3:-main}"

  mkdir -p "$(dirname "$PROJECTS_JSON")"
  if [ ! -f "$PROJECTS_JSON" ]; then
    echo "{}" > "$PROJECTS_JSON"
    chmod 600 "$PROJECTS_JSON"
  fi

  local tmp
  tmp="$(mktemp "${PROJECTS_JSON}.XXXXXX")"
  jq \
    --arg slug "$slug" \
    --arg repo "$repo" \
    --arg branch "$default_branch" \
    '.[$slug] = { repo: $repo, defaultBranch: $branch }' \
    "$PROJECTS_JSON" > "$tmp"
  chmod 600 "$tmp"
  mv "$tmp" "$PROJECTS_JSON"
}

# ── Add-repo mode: append project to projects.json ──────────────────

if [ "$ADD_REPO_MODE" = true ]; then
  if [ ! -f "$PROJECTS_JSON" ]; then
    echo "ERROR: No $PROJECTS_JSON found."
    echo "Run zapbot-team-init <owner/repo> first."
    exit 1
  fi

  if jq -e --arg slug "$REPO_NAME" '.[$slug]' "$PROJECTS_JSON" >/dev/null 2>&1; then
    echo "ERROR: ${REPO_NAME} is already registered in $PROJECTS_JSON"
    exit 1
  fi

  echo "=== Adding repo: $ZAPBOT_REPO ==="
  echo ""
  echo "--- Creating labels on $ZAPBOT_REPO ---"
  create_labels "$ZAPBOT_REPO"

  echo ""
  echo "--- Registering project in $PROJECTS_JSON ---"
  upsert_project_entry "$REPO_NAME" "$ZAPBOT_REPO" "main"
  echo "  Added project: $REPO_NAME (${ZAPBOT_REPO})"

  echo ""
  echo "================================================"
  echo "  Added $ZAPBOT_REPO to zapbot!"
  echo "================================================"
  echo ""
  echo "Reload the orchestrator + bridge to pick up the new project:"
  if systemctl is-active zapbot-bridge >/dev/null 2>&1; then
    sudo systemctl reload zapbot-bridge 2>/dev/null && echo "  Bridge reloaded." || echo "  Run: sudo systemctl reload zapbot-bridge"
  else
    echo "  Restart ./start.sh"
  fi
  echo ""
  exit 0
fi

# ── Full init mode (first repo) ────────────────────────────────────

echo "=== Zapbot Team Init ==="
echo "Repo: $ZAPBOT_REPO"
echo ""

echo "--- Creating labels ---"
create_labels "$ZAPBOT_REPO"

echo ""
echo "--- Registering project in $PROJECTS_JSON ---"
upsert_project_entry "$REPO_NAME" "$ZAPBOT_REPO" "main"
echo "  Registered $REPO_NAME (${ZAPBOT_REPO})"

echo ""
echo "--- Environment setup ---"
CONFIG_JSON="$HOME/.zapbot/config.json"
mkdir -p "$HOME/.zapbot"
GENERATED_API_KEY=$(openssl rand -hex 32 2>/dev/null || head -c 32 /dev/urandom | xxd -p | tr -d '\n')
GENERATED_WEBHOOK_SECRET=$(openssl rand -hex 32 2>/dev/null || head -c 32 /dev/urandom | xxd -p | tr -d '\n')
if [ -f "$CONFIG_JSON" ]; then
  # Merge new keys; preserve any existing keys already set
  UPDATED=$(jq \
    --arg wh "$GENERATED_WEBHOOK_SECRET" \
    --arg ak "$GENERATED_API_KEY" \
    'if (.webhookSecret | type) == "string" and (.webhookSecret | length) > 0 then . else .webhookSecret = $wh end |
     if (.apiKey | type) == "string" and (.apiKey | length) > 0 then . else .apiKey = $ak end' \
    "$CONFIG_JSON")
  echo "$UPDATED" > "$CONFIG_JSON"
  chmod 600 "$CONFIG_JSON"
  echo "  Updated $CONFIG_JSON (preserved existing keys, filled missing ones)"
else
  printf '{\n  "webhookSecret": "%s",\n  "apiKey": "%s"\n}\n' \
    "$GENERATED_WEBHOOK_SECRET" "$GENERATED_API_KEY" > "$CONFIG_JSON"
  chmod 600 "$CONFIG_JSON"
  echo "  Generated $CONFIG_JSON with webhookSecret + apiKey"
fi

echo ""
echo "--- Webhook setup ---"
echo "  Configure a GitHub App or repo webhook to deliver to:"
echo "    <bridge or gateway URL>/api/webhooks/github"
echo "  Use ZAPBOT_WEBHOOK_SECRET as the webhook secret."
echo "  ZAPBOT_API_KEY is the broker bearer — it stays local."

echo ""
if systemctl is-active zapbot-bridge >/dev/null 2>&1; then
  echo "Reloading bridge config (systemd service detected)..."
  sudo systemctl reload zapbot-bridge 2>/dev/null && echo "  Bridge reloaded." || echo "  WARNING: Could not reload. Run: sudo systemctl reload zapbot-bridge"
fi

echo ""
echo "================================================"
echo "  Team init complete for $ZAPBOT_REPO!"
echo "================================================"
echo ""
echo "Next steps:"
if systemctl is-active zapbot-bridge >/dev/null 2>&1; then
  echo "  1. Bridge is running (systemd). Config was auto-reloaded."
else
  echo "  1. Run $ZAPBOT_DIR/start.sh . to start moltzap-server + orchestrator + bridge"
fi
echo "  2. Mention @zapbot on an issue to kick off a plan or investigation"
echo "     The orchestrator resumes the project's lead Claude session and dispatches workers"
echo ""
echo "To add another repo later:"
echo "  $ZAPBOT_DIR/bin/zapbot-team-init --add-repo <owner/other-repo>"
echo ""
