#!/usr/bin/env bash
set -euo pipefail

# Zapbot setup — installs dependencies for the zapbot tool itself.
# Run once after cloning: cd ~/.claude/skills/zapbot && ./setup
#
# Modes:
#   ./setup            Teammate install (skill only, no server deps)
#   ./setup --server   Server install (adds ngrok, agent-orchestrator, tmux/jq/node prereqs)
#   ./setup --help     Show usage

ZAPBOT_DIR="$(cd "$(dirname "$0")" && pwd)"

# --- Parse flags ---
SERVER_MODE=false
for arg in "$@"; do
  case "$arg" in
    --server) SERVER_MODE=true ;;
    --help|-h)
      echo "Usage: ./setup [--server]"
      echo ""
      echo "  (no flags)   Teammate install — skill + minimal deps"
      echo "  --server     Server install — adds orchestrator deps (ao, tmux, jq, node)"
      echo "  --help       Show this help"
      exit 0
      ;;
    *)
      echo "Unknown flag: $arg"
      echo "Run ./setup --help for usage."
      exit 1
      ;;
  esac
done

if $SERVER_MODE; then
  echo "=== Zapbot Server Setup ==="
else
  echo "=== Zapbot Setup ==="
fi
echo ""

# --- Check prerequisites ---
MISSING=""
command -v git >/dev/null 2>&1 || MISSING="$MISSING git"
command -v gh >/dev/null 2>&1 || MISSING="$MISSING gh"

if $SERVER_MODE; then
  command -v node >/dev/null 2>&1 || MISSING="$MISSING node"
  command -v tmux >/dev/null 2>&1 || MISSING="$MISSING tmux"
  command -v jq >/dev/null 2>&1 || MISSING="$MISSING jq"
fi

if [ -n "$MISSING" ]; then
  echo "ERROR: Missing:$MISSING"
  exit 1
fi

# --- Install bun (if missing) ---
if ! command -v bun >/dev/null 2>&1; then
  echo "Installing bun..."
  curl -fsSL https://bun.sh/install | bash
fi

# --- Install npm dependencies ---
echo "Installing dependencies..."
(cd "$ZAPBOT_DIR" && bun install --frozen-lockfile 2>/dev/null || cd "$ZAPBOT_DIR" && bun install)

# --- Server-only installs ---
if $SERVER_MODE; then
  # Install agent-orchestrator (if missing)
  if ! command -v ao >/dev/null 2>&1; then
    echo "Installing agent-orchestrator..."
    if command -v npm >/dev/null 2>&1; then
      npm install -g @aoagents/ao
    elif command -v bun >/dev/null 2>&1; then
      bun install -g @aoagents/ao
    else
      echo "WARNING: Neither npm nor bun found. Install @aoagents/ao manually."
    fi
  fi

  # Validate server installs
  echo ""
  echo "Validating server dependencies..."
  if command -v ao >/dev/null 2>&1; then
    echo "  agent-orchestrator: $(ao --version 2>&1 || echo 'installed')"
  else
    echo "  WARNING: ao not found after install"
  fi

  # Generate systemd service file
  echo ""
  echo "--- Systemd service ---"
  SERVICE_FILE="$ZAPBOT_DIR/zapbot-bridge.service"
  sed "s|__PROJECT_DIR__|$(pwd)|g; s|__ZAPBOT_DIR__|$ZAPBOT_DIR|g" \
    "$ZAPBOT_DIR/templates/zapbot-bridge.service" > "$SERVICE_FILE"
  echo "  Generated: $SERVICE_FILE"
  echo ""
  echo "  To install as a systemd service (auto-start on boot, auto-restart on crash):"
  echo "    sudo cp $SERVICE_FILE /etc/systemd/system/zapbot-bridge.service"
  echo "    sudo systemctl enable --now zapbot-bridge"
  echo ""
  echo "  To reload config without restart (after changing .env or agent-orchestrator.yaml):"
  echo "    sudo systemctl reload zapbot-bridge"
fi

# Claude Code only scans ~/.claude/skills/*/SKILL.md (one level deep).
# Repo symlink provides bin/ path resolution for SKILL.md references.
link_skill_dirs() {
  local zapbot_dir="$1"
  local skills_dir="$2"
  local linked=()
  local dir_name skill_name target
  for skill_dir in "$zapbot_dir"/skills/*/; do
    [ -f "$skill_dir/SKILL.md" ] || continue
    dir_name="$(basename "$skill_dir")"
    skill_name=$(grep -m1 '^name:' "$skill_dir/SKILL.md" 2>/dev/null \
      | sed 's/^name:[[:space:]]*//' | tr -d '[:space:]')
    [ -z "$skill_name" ] && skill_name="$dir_name"
    # Guard: don't clobber the repo-level symlink
    [ "$skill_name" = "zapbot" ] && skill_name="$dir_name"
    target="$skills_dir/$skill_name"
    rm -rf "$target" 2>/dev/null || true
    mkdir -p "$target"
    ln -snf "$zapbot_dir/skills/$dir_name/SKILL.md" "$target/SKILL.md"
    linked+=("$skill_name")
  done
  [ ${#linked[@]} -gt 0 ] && echo "  Linked skills: ${linked[*]}"
}

SKILLS_DIR="$HOME/.claude/skills"
mkdir -p "$SKILLS_DIR"
ln -snf "$ZAPBOT_DIR" "$SKILLS_DIR/zapbot"
link_skill_dirs "$ZAPBOT_DIR" "$SKILLS_DIR"

# Make scripts executable
chmod +x "$ZAPBOT_DIR/bin/"* "$ZAPBOT_DIR/setup" "$ZAPBOT_DIR/start.sh" 2>/dev/null || true

# Create ~/.zapbot/ dir
STATE_DIR="$HOME/.zapbot"
mkdir -p "$STATE_DIR"

# Write upgrade marker if version changed (for manual `git pull && ./setup` upgrades)
MARKER_FILE="$STATE_DIR/just-upgraded-from"
NEW_VERSION=$(cat "$ZAPBOT_DIR/VERSION" 2>/dev/null || echo "0.0.0")
if [ -f "$MARKER_FILE.prev" ]; then
  PREV_VERSION=$(cat "$MARKER_FILE.prev" 2>/dev/null || echo "")
  if [ -n "$PREV_VERSION" ] && [ "$PREV_VERSION" != "$NEW_VERSION" ]; then
    mkdir -p "$STATE_DIR"
    echo "$PREV_VERSION" > "$MARKER_FILE"
  fi
  rm -f "$MARKER_FILE.prev"
elif [ -f "$STATE_DIR/installed-version" ]; then
  PREV_VERSION=$(cat "$STATE_DIR/installed-version" 2>/dev/null || echo "")
  if [ -n "$PREV_VERSION" ] && [ "$PREV_VERSION" != "$NEW_VERSION" ]; then
    mkdir -p "$STATE_DIR"
    echo "$PREV_VERSION" > "$MARKER_FILE"
  fi
fi
echo "$NEW_VERSION" > "$STATE_DIR/installed-version"

echo ""
echo "================================================"
if $SERVER_MODE; then
  echo "  Zapbot server v$(cat "$ZAPBOT_DIR/VERSION") installed!"
  echo "================================================"
  echo ""
  echo "To onboard a repo:"
  echo "  cd ~/your-project"
  echo "  ~/.claude/skills/zapbot/bin/zapbot-team-init <owner/repo>"
  echo ""
  echo "To start the server:"
  echo "  cd ~/your-project"
  echo "  ~/.claude/skills/zapbot/start.sh ."
else
  echo "  Zapbot skill v$(cat "$ZAPBOT_DIR/VERSION") installed!"
  echo "================================================"
  echo ""
  echo "Zapbot skill installed! Run /zapbot-publish in Claude Code to get started."
fi
echo ""
