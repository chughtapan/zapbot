# Shared secret for bridge registration authentication.
# Bridges must send this as Bearer token when registering/deregistering.
GATEWAY_SECRET=change-me-to-a-random-secret

# Port the gateway listens on. Railway sets this automatically.
# PORT=8080

# How often to ping registered bridges for liveness (ms).
# LIVENESS_INTERVAL_MS=30000

# How long before an unresponsive bridge is marked inactive (ms).
# STALE_TIMEOUT_MS=60000

# Timeout for forwarding webhook requests to bridges (ms).
# FORWARD_TIMEOUT_MS=30000
